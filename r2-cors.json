{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://nobiliview-app.vercel.app",
          "http://localhost:3000",
          "http://127.0.0.1:3000"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "Content-Type"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
